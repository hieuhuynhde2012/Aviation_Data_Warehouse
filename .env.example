PROJECT_NAME=aviation-data-warehouse

# Local service ports
AIRFLOW_WEB_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
WAREHOUSE_PORT=5433
SUPERSET_PORT=8088
SPARK_MASTER_UI_PORT=8081
SPARK_WORKER_UI_PORT=8082
SPARK_MASTER_PORT=7077

# Airflow
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Warehouse
WAREHOUSE_HOST=postgres-warehouse
WAREHOUSE_DB=aviation_dw
WAREHOUSE_USER=aviation
WAREHOUSE_PASSWORD=aviation
WAREHOUSE_SCHEMA_RAW=raw

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_RAW=aviation-raw
MINIO_BUCKET_ARCHIVE=aviation-archive
MINIO_BUCKET_QUALITY=aviation-quality-reports

# Data sources
BTS_YEAR=2026
BTS_MONTH=4
BTS_URL_TEMPLATE=https://transtats.bts.gov/PREZIP/On_Time_Reporting_Carrier_On_Time_Performance_1987_present_{year}_{month}.zip
OURAIRPORTS_AIRPORTS_URL=https://davidmegginson.github.io/ourairports-data/airports.csv
OURAIRPORTS_COUNTRIES_URL=https://davidmegginson.github.io/ourairports-data/countries.csv
OURAIRPORTS_REGIONS_URL=https://davidmegginson.github.io/ourairports-data/regions.csv

# Synthetic data
SYNTHETIC_SEED=42
BOOKINGS_PER_FLIGHT_MIN=30
BOOKINGS_PER_FLIGHT_MAX=180
MAX_FLIGHTS_FOR_SYNTHETIC=2000
SYNTHETIC_TARGET_ROWS=100000
CURRENCY=USD

# Dirty data profile for DE cleaning/standardization practice
DIRTY_DATA_RATE=0.08
DUPLICATE_EVENT_RATE=0.03
MISSING_OPTIONAL_RATE=0.02
PAYMENT_MISMATCH_RATE=0.015
CRITICAL_INVALID_RATE=0.003

# Spark
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g
